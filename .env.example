# EduClaw Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git!

# === REQUIRED ===
TELEGRAM_BOT_TOKEN=           # From @BotFather on Telegram
ANTHROPIC_API_KEY=            # From console.anthropic.com

# === OPTIONAL ===
SENDGRID_API_KEY=             # From sendgrid.com (free tier: 100 emails/day)
INSTRUCTOR_EMAIL=             # Where weekly reports are emailed

# === SYSTEM CONFIG ===
OPENCLAW_PORT=3000            # Gateway WebSocket port
SKILLS_RUNTIME_PORT=8001      # Internal skills API port
DATA_DIR=./data               # Data directory (use /data in Docker)
LOG_LEVEL=info                # info | debug | warning | error
NODE_ENV=development          # production | development
DEFAULT_COURSE_TIMEZONE=Asia/Kolkata  # IST for Indian deployments
